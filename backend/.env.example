# ─────────────────────────────────────────────────────────────────────────────
# PekoHub Backend Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL)
# Local dev (docker-compose): postgres://pekohub:pekohub@localhost:5433/pekohub
# Production (RDS): postgres://user:password@host:5432/pekohub?sslmode=require
DATABASE_URL=postgres://pekohub:pekohub@localhost:5433/pekohub

# Object Storage (S3-compatible)
# Local dev (MinIO): http://localhost:9000
# Production (AWS S3): https://s3.us-east-1.amazonaws.com
# Production (Cloudflare R2): https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=pekohub
S3_SECRET_KEY=pekohubpekohub
S3_BUCKET=pekohub-blobs
# Set to 'true' for MinIO, 'false' for AWS S3 / R2
S3_FORCE_PATH_STYLE=true

# Search (Meilisearch)
# Local dev: http://localhost:7700
# Production (Meilisearch Cloud): https://ms-xxx.meilisearch.io
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=pekohub-master-key

# Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production-use-a-long-random-string-min-32-chars

# GitHub OAuth (optional)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (optional)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Registry public URL
# Used for OAuth callbacks and API responses
# Local dev: http://localhost:3000
# Production: https://api.pekohub.ai
REGISTRY_BASE_URL=http://localhost:3000

# Dev auth bypass (DANGEROUS — never enable in production)
ALLOW_DEV_AUTH_BYPASS=false

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Garbage collection
GC_ENABLED=true
GC_INTERVAL_MS=86400000
GC_RETENTION_DAYS=7
GC_BATCH_SIZE=1000
