# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgres://pekohub:pekohub@localhost:5432/pekohub

# Object Storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=pekohub
S3_SECRET_KEY=pekohubpekohub
S3_BUCKET=pekohub-blobs
S3_FORCE_PATH_STYLE=true

# Search
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=pekohub-master-key

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Registry
REGISTRY_BASE_URL=http://localhost:3000
